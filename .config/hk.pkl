amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"

exclude = List(
	"gradlew",
	"gradlew.bat",
	"pnpm-lock.yaml",
	".idea/**",
)

local frontend = new Mapping<String, Step> {
	["eslint"] = (Builtins.eslint) {
		glob = List("**/*.js", "**/*.ts", "**/*.vue")
		check = "cd {{workspace}} && pnpm eslint {{workspace_files}}"
		fix = "cd {{workspace}} && pnpm eslint --fix {{workspace_files}}"
		workspace_indicator = "package.json"
	}
}

local backend = new Mapping<String, Step> {
	// If we decide this is too slow, consider using only Ktlint (via Mise)?
	["detekt"] {
		// Running type-aware lints is kinda slow, so let's run it on the CI only
		local detekt_cmd = "just gradle detekt"

		glob = List("**/*.kt", "**/*.kts")
		check = detekt_cmd
		check_first = false  // Gradle's too slow for that

		// Detekt is weird and needs multiple passes to fix things..? Some fixes generate new problems causing false negatives.
		// First run is `|| true`'d, so it always does 2 passes and only fails if the 2nd pass is unsuccessful.
		// This solves some weird situations where the run fails despite the fixes being applied.
		local _fix = detekt_cmd + " -Pdetekt.fix"
		fix = "(" + _fix + " || true) && " + _fix
	}
}

local ci = new Mapping<String, Step> {
	["actionlint"] = (Builtins.actionlint)
	["zizmor"] = (Builtins.zizmor)
}

// Shared linters (apply to all components)
local shared = new Mapping<String, Step> {
	// Might be good to have at some point, but unclear how it'll play with Nuxt MDC (MDCLint?)
	// ["markdown"] = (Builtins.markdown_lint)
	["taplo"] = (Builtins.taplo)
	["taplo-format"] = (Builtins.taplo_format)

	["pkl"] = (Builtins.pkl)

	["typos"] = (Builtins.typos) {
		check_diff = Builtins.typos.check_diff.replaceAll("typos", "typos --config .config/typos/config.toml")
		fix = Builtins.typos.fix.replaceAll("typos", "typos --config .config/typos/config.toml")
	}

	// Builtin hk checks
	["byte-order-marker"] = (Builtins.byte_order_marker)
	["trailing-whitespace"] = (Builtins.trailing_whitespace)
	["check-added-large-files"] = (Builtins.check_added_large_files)
	["check-merge-conflict"] = (Builtins.check_merge_conflict)
}

// Merge all in a flat object (so hk does run everything in parallel)
local check_steps = new Mapping<String, Step> {
	...frontend
	...backend
	...ci
	...shared
}

hooks {
	["pre-commit"] {
		fix = true
		stash = "git"
		steps = check_steps
	}
	["commit-msg"] {
		steps {
			["conventional-commits"] = (Builtins.check_conventional_commit) {
				// Workaround for https://github.com/jdx/hk/discussions/902
				// Allows `fixup!`, `amend!`, and `squash!` commits for git autosquashing.
				check = "./.config/conventional-check.sh {{commit_msg_file}}"
			}
		}
	}
	["check"] {
		steps = check_steps
	}
	["fix"] {
		fix = true
		stash = "none"
		steps = check_steps
	}
}
